{
  "SessionStart": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "bash ${PLUGIN_ROOT}/hooks/scripts/session-start.sh",
          "timeout": 15,
          "statusMessage": "Connecting to McpServer..."
        }
      ]
    }
  ],
  "SessionEnd": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "bash ${PLUGIN_ROOT}/hooks/scripts/session-end.sh",
          "timeout": 10,
          "statusMessage": "Finalizing MCP session..."
        }
      ]
    }
  ],
  "PreCompact": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "bash ${PLUGIN_ROOT}/hooks/scripts/pre-compact.sh",
          "timeout": 10,
          "statusMessage": "Persisting session state..."
        }
      ]
    }
  ],
  "PostCompact": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "bash ${PLUGIN_ROOT}/hooks/scripts/post-compact.sh",
          "timeout": 15,
          "statusMessage": "Reloading MCP context..."
        }
      ]
    }
  ],
  "UserPromptSubmit": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "bash ${PLUGIN_ROOT}/hooks/scripts/user-prompt-submit.sh",
          "timeout": 10,
          "statusMessage": "Opening session log turn..."
        }
      ]
    }
  ],
  "Stop": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "bash ${PLUGIN_ROOT}/hooks/scripts/stop-gate.sh",
          "timeout": 10,
          "statusMessage": "Verifying session log + build gates..."
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "ExitPlanMode",
      "hooks": [
        {
          "type": "command",
          "command": "bash ${PLUGIN_ROOT}/hooks/scripts/plan-approved.sh",
          "timeout": 15,
          "statusMessage": "Creating MCP TODO for approved plan..."
        }
      ]
    },
    {
      "matcher": "Write|Edit",
      "hooks": [
        {
          "type": "command",
          "command": "bash ${PLUGIN_ROOT}/hooks/scripts/plan-modified.sh",
          "if": "Write(**/plans/**)|Edit(**/plans/**)",
          "timeout": 10,
          "statusMessage": "Syncing plan changes to MCP TODO..."
        },
        {
          "type": "command",
          "command": "bash ${PLUGIN_ROOT}/hooks/scripts/code-verify.sh",
          "timeout": 120,
          "statusMessage": "Verifying build after code edit..."
        }
      ]
    }
  ]
}
